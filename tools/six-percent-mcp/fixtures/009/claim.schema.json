{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "claim.schema.json",
  "title": "AutoClaim",
  "type": "object",
  "required": ["claim_id", "submitted_at", "policyholder", "incident", "vehicle", "amounts"],
  "properties": {
    "claim_id":     { "type": "string", "pattern": "^[A-Z]{3}-\\d{4}-\\d+$" },
    "submitted_at": { "type": "string", "format": "date-time" },
    "channel":      { "type": "string", "enum": ["mobile app", "web", "phone", "email", "agent"] },

    "policyholder": {
      "type": "object",
      "required": ["name", "dob", "ssn", "policy_number"],
      "properties": {
        "name":          { "type": "string", "minLength": 2 },
        "dob":           { "type": "string", "format": "date" },
        "ssn":           { "type": "string", "pattern": "^\\d{3}-\\d{2}-\\d{4}$" },
        "policy_number": { "type": "string" },
        "phone":         { "type": "string" },
        "email":         { "type": "string", "format": "email" },
        "address": {
          "type": "object",
          "properties": {
            "street": { "type": "string" },
            "unit":   { "type": ["string", "null"] },
            "city":   { "type": "string" },
            "state":  { "type": "string", "minLength": 2, "maxLength": 2 },
            "zip":    { "type": "string", "pattern": "^\\d{5}(-\\d{4})?$" }
          }
        }
      }
    },

    "incident": {
      "type": "object",
      "required": ["date_of_loss", "location"],
      "properties": {
        "date_of_loss": { "type": "string", "format": "date" },
        "time":         { "type": "string" },
        "location":     { "type": "string" },
        "conditions":   { "type": "string" },
        "police_report": {
          "type": "object",
          "properties": {
            "present":       { "type": "boolean" },
            "agency":        { "type": ["string", "null"] },
            "report_number": { "type": ["string", "null"] }
          }
        },
        "other_party": {
          "type": "object",
          "properties": {
            "present":       { "type": "boolean" },
            "driver_name":   { "type": ["string", "null"] },
            "insurer":       { "type": ["string", "null"] },
            "policy_number": { "type": ["string", "null"] }
          }
        }
      }
    },

    "description": { "type": "string" },

    "vehicle": {
      "type": "object",
      "required": ["year", "make", "model", "vin"],
      "properties": {
        "year":                 { "type": "integer", "minimum": 1900, "maximum": 2100 },
        "make":                 { "type": "string" },
        "model":                { "type": "string" },
        "trim":                 { "type": ["string", "null"] },
        "vin":                  { "type": "string", "pattern": "^[A-HJ-NPR-Z0-9]{17}$" },
        "license_plate":        { "type": ["string", "null"] },
        "damage_summary":       { "type": "string" },
        "repair_estimate_usd":  { "type": "number", "minimum": 0 }
      }
    },

    "amounts": {
      "type": "object",
      "required": ["total_claimed", "deductible", "net_claim"],
      "properties": {
        "vehicle_repair":   { "type": "number", "minimum": 0 },
        "rental_coverage":  { "type": "number", "minimum": 0 },
        "diminished_value": { "type": "number", "minimum": 0 },
        "total_claimed":    { "type": "number", "minimum": 0 },
        "deductible":       { "type": "number", "minimum": 0 },
        "net_claim":        { "type": "number", "minimum": 0 }
      }
    },

    "attachments": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["type", "description"],
        "properties": {
          "type":        { "type": "string", "enum": ["photo", "pdf", "video", "audio", "other"] },
          "description": { "type": "string" }
        }
      }
    },

    "consent": {
      "type": "object",
      "properties": {
        "recorded_statement":      { "type": "boolean" },
        "inspection_window_days":  { "type": "integer", "minimum": 0 }
      }
    },

    "signature": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "date": { "type": "string", "format": "date" }
      }
    }
  },
  "businessRules": [
    {
      "id": "amounts_consistent",
      "description": "vehicle_repair + rental_coverage + diminished_value should equal total_claimed (± $1)",
      "tolerance_usd": 1
    },
    {
      "id": "net_claim_consistent",
      "description": "net_claim should equal total_claimed - deductible (± $1)",
      "tolerance_usd": 1
    },
    {
      "id": "loss_before_submission",
      "description": "incident.date_of_loss must be on or before submitted_at"
    },
    {
      "id": "policyholder_age",
      "description": "policyholder.dob implies age >= 16 at date_of_loss"
    }
  ]
}
