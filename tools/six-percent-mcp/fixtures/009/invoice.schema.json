{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "invoice.schema.json",
  "title": "Invoice",
  "type": "object",
  "required": ["invoice_number", "issue_date", "due_date", "vendor", "bill_to", "line_items", "subtotal", "total"],
  "properties": {
    "invoice_number": { "type": "string", "minLength": 1 },
    "issue_date":     { "type": "string", "format": "date" },
    "due_date":       { "type": "string", "format": "date" },
    "terms":          { "type": "string" },
    "po_number":      { "type": ["string", "null"] },

    "vendor": {
      "type": "object",
      "required": ["name", "address"],
      "properties": {
        "name":    { "type": "string" },
        "address": { "type": "string" },
        "tax_id":  { "type": ["string", "null"] }
      }
    },

    "bill_to": {
      "type": "object",
      "required": ["name", "address"],
      "properties": {
        "name":       { "type": "string" },
        "attn_name":  { "type": ["string", "null"] },
        "attn_email": { "type": ["string", "null"], "format": "email" },
        "address":    { "type": "string" }
      }
    },

    "ship_to": {
      "type": ["object", "null"],
      "properties": {
        "name":    { "type": "string" },
        "address": { "type": "string" }
      }
    },

    "line_items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["description", "qty", "unit_price", "amount"],
        "properties": {
          "number":      { "type": ["integer", "null"], "minimum": 1 },
          "description": { "type": "string", "minLength": 1 },
          "qty":         { "type": "number", "minimum": 0 },
          "unit_price":  { "type": "number", "minimum": 0 },
          "amount":      { "type": "number", "minimum": 0 }
        }
      }
    },

    "subtotal":    { "type": "number", "minimum": 0 },
    "tax":         { "type": "number", "minimum": 0 },
    "total":       { "type": "number", "minimum": 0 },

    "payment": {
      "type": ["object", "null"],
      "properties": {
        "method":          { "type": "string", "enum": ["ACH", "wire", "check", "card"] },
        "routing":         { "type": ["string", "null"] },
        "account":         { "type": ["string", "null"] },
        "bank":            { "type": ["string", "null"] },
        "late_fee_pct":    { "type": ["number", "null"], "minimum": 0 }
      }
    },

    "contact": {
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" }
      }
    }
  },
  "businessRules": [
    {
      "id": "line_items_sum_to_subtotal",
      "description": "Sum of line_items[].amount must equal subtotal (± $0.01)",
      "tolerance_usd": 0.01
    },
    {
      "id": "subtotal_plus_tax_equals_total",
      "description": "subtotal + tax must equal total (± $0.01)",
      "tolerance_usd": 0.01
    },
    {
      "id": "line_amount_consistent",
      "description": "Each line_item: qty × unit_price must equal amount (± $0.01)",
      "tolerance_usd": 0.01
    },
    {
      "id": "due_after_issue",
      "description": "due_date must be on or after issue_date"
    }
  ]
}
